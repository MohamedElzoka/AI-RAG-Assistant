# ============================================================
# .env.example - نسخ الملف ده لـ .env وحط القيم الصح
# ============================================================

# --- OpenAI (اختياري - لو عندك API key) ---
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4o-mini

# --- Ollama Local LLM (مجاني - بيشتغل على جهازك) ---
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# --- إعدادات الـ LLM ---
LLM_PROVIDER=ollama          # openai أو ollama
LLM_TEMPERATURE=0.7          # إبداعية الإجابات (0.0 = محدد, 1.0 = إبداعي)
LLM_MAX_TOKENS=2048          # الحد الأقصى للـ tokens في الرد

# --- إعدادات الـ RAG ---
CHUNK_SIZE=500               # حجم كل chunk من النص
CHUNK_OVERLAP=50             # التداخل بين الـ chunks
TOP_K_RESULTS=5              # عدد النتائج المسترجعة من الـ vector store

# --- إعدادات الـ Embeddings ---
EMBEDDING_MODEL=all-MiniLM-L6-v2  # نموذج محلي مجاني
VECTOR_DB_PATH=./data/vectordb      # مكان حفظ الـ vector database

# --- إعدادات الـ API ---
API_HOST=0.0.0.0
API_PORT=8000
API_DEBUG=false

# --- Logging ---
LOG_LEVEL=INFO
